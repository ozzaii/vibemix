{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/vibemix/vibemix/blob/main/scripts/audit/dep_ratings_schema.json",
  "title": "vibemix dep_ratings.yaml schema",
  "description": "Phase 46 / DEPS-04 — validates the structure of scripts/audit/dep_ratings.yaml. Each ecosystem maps package names to a rating + rationale. Phase 48 / OPP-02 — extended with opportunity_evaluations array (new-dep + integration scan rows under 4-color rubric).",
  "type": "object",
  "additionalProperties": false,
  "required": ["python", "rust", "js", "opportunity_evaluations"],
  "properties": {
    "python": { "$ref": "#/$defs/ecosystem" },
    "rust":   { "$ref": "#/$defs/ecosystem" },
    "js":     { "$ref": "#/$defs/ecosystem" },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "target", "action", "rationale"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "target": { "type": "string" },
          "action": {
            "type": "string",
            "enum": ["removed", "retained-as-transitive", "cull-deferred", "cull-blocked"]
          },
          "rationale": {
            "type": "string",
            "minLength": 20
          }
        }
      }
    },
    "opportunity_evaluations": {
      "type": "array",
      "items": { "$ref": "#/$defs/opportunity_entry" }
    }
  },
  "$defs": {
    "ecosystem": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/rating_entry" }
    },
    "rating_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rating", "rationale"],
      "properties": {
        "rating": {
          "type": "string",
          "enum": ["green", "yellow", "red"]
        },
        "rationale": {
          "type": "string",
          "minLength": 10,
          "maxLength": 600
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "opportunity_entry": {
      "type": "object",
      "required": ["id", "date", "candidate", "category", "rating", "install_impact", "rationale", "integration_surface", "rejected_constraints", "adr_sidecar"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^DEP-OPP-[0-9]{2}$" },
        "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "candidate": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["python-dep", "rust-dep", "js-dep", "integration", "os-support", "hardware-support"]
        },
        "rating": {
          "type": "string",
          "enum": ["green-adopt", "yellow-defer", "red-constraint", "red-risk"]
        },
        "install_impact": {
          "type": "string",
          "enum": ["green", "yellow", "red", "n/a"]
        },
        "rationale": {
          "type": "string",
          "minLength": 20,
          "maxLength": 800
        },
        "integration_surface": {
          "type": "string",
          "enum": ["runtime", "build-time", "test-time", "docs-only", "ci-only", "none"]
        },
        "rejected_constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["memory", "quote"],
            "additionalProperties": false,
            "properties": {
              "memory": { "type": "string", "minLength": 1 },
              "quote": { "type": "string", "minLength": 10 }
            }
          }
        },
        "adr_sidecar": { "type": "string" }
      }
    }
  }
}
