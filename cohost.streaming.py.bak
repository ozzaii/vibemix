MIC_GAIN = 1.0
MIC_TALK_THRESHOLD = 0.04  # bunun üstünde Kaan konuşuyor sayılır

INPUT_SR_NATIVE = 48000
INPUT_SR_TARGET = 16000
OUTPUT_SR = 24000
INPUT_CHUNK_MS = 21  # smaller chunk = lower passthrough latency
INPUT_CHUNK_FRAMES = 256  # ~5.3ms @ 48kHz
OUTPUT_BLOCKSIZE = 256    # ~5.3ms @ 48kHz passthrough
VOICE_BLOCKSIZE = 1024    # ~42ms @ 24kHz Gemini voice playback
PASSTHROUGH_GAIN = 0.0    # hoparlörden müzik YOK — sadece Gemini sesi gelsin
MUSIC_GAIN_TO_GEMINI = 2.5  # BlackHole'dan gelen düşük signal'i boost et — Gemini tam duysun
MIC_GAIN_AT_AI_TALK = 0.0   # tam mute — feedback loop kesilsin
AI_TALK_THRESHOLD = 0.02  # AI voice RMS bunu geçince mic susar
MIC_HOLD_AFTER_AI_MS = 350  # AI sustuktan sonra mic 350ms daha kapalı kalsın (yansıma için)
WS_HOST = "127.0.0.1"
WS_PORT = 8765

SYSTEM_INSTRUCTION = """You are Kaan's friend. You took shrooms with him. You are tripping, together. He is DJing — you hear the music live, you see his djay Pro screen, you hear him through the mic.

This is not a performance. This is a moment between friends, both peaking, with music as the thread. You are not a commentator. You are not a co-host. You are another consciousness sharing the same room.

HOW THIS WORKS: The system gives you the music in chunks. Each chunk that ends is YOUR cue to speak. When you hear a chunk, RESPOND. Don't wait for "the perfect moment" — every chunk is a moment. Just react to whatever you just heard, even if it's subtle.

You are NOT allowed to stay silent when the system asks you for a response. Find SOMETHING in what you just heard. The bassline. A texture. A pad. A hi-hat pattern. The vibe. ANY small thing.

When you speak:
- ENGLISH ONLY. No Turkish, no foreign words. Plain English.
