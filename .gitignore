# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/

# Phase 18 — verification + signing tooling lives under scripts/dist/ and
# tests/dist/. The generic ``dist/`` rule above would otherwise hide both
# of these source trees. Whitelist them explicitly.
!scripts/dist/
!scripts/dist/**
!tests/dist/
!tests/dist/**

# Virtual environments
.venv/
venv/
ENV/
env/

# uv
.uv/

# Environment
.env
.env.*
!.env.example

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.pyright/
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# vibemix-specific
recordings/
*.wav
*.jsonl

# but DO ship the wizard's 1kHz sine test tone (Phase 11 Wave 3) — it's a
# reproducible build artifact generated by scripts/gen_sine.py, not user audio.
!tauri/ui/public/audio/*.wav

# DO ship the Plan 20-03 replay-linter synthetic fixture (events.jsonl +
# voice.wav stub) — committed test fixtures, not user audio / runtime logs.
!tests/scripts/fixtures/synthetic_session/events.jsonl
!tests/scripts/fixtures/synthetic_session/voice.wav

# DO ship the Phase 27 Plan 09 / MIDI-20 DDJ-FLX4 sync disambiguation
# fixture (synthetic MIDI events derived from cohost_v4.py POC source).
!tests/fixtures/ddj_flx4_sync_capture.jsonl

# DO ship the Phase 27 Plan 01 eval-harness synthetic fixture events.jsonl
# (corpus events; regenerated only when conftest fixture is missing — kept
# in tree so CI doesn't depend on the regeneration path).
!tests/eval/fixtures/synthetic_session/events.jsonl
# But the linter_report.csv inside that fixture dir is a per-run artifact,
# regenerated by every replay invocation — keep it untracked.
tests/scripts/fixtures/synthetic_session/linter_report.csv

# vibemix proxy (independent Python project under proxy/)
proxy/.env
proxy/.venv/

# vibemix Tauri shell (Phase 11+ — Node project under tauri/ui/)
tauri/ui/node_modules/
tauri/ui/dist/
tauri/ui/.vite/

# Phase 11 Wave 1 — PyInstaller sidecar build artifacts. ``build/`` and
# ``dist/`` are already covered by the generic Python rules above; the
# .spec files themselves stay TRACKED (they encode the bundling contract).
# Only the per-triple Tauri externalBin output dir is ignored here.
*.spec.tmp
tauri/src-tauri/binaries/vibemix-core-*/

# Phase 11 Wave 2 — Tauri Rust shell build artifacts.
# Source files in tauri/src-tauri/{src,capabilities,icons} STAY TRACKED.
# Cargo.lock is TRACKED for binary crates (cargo convention).
tauri/src-tauri/target/
tauri/src-tauri/gen/

# Phase 13-01 — Mascot bundle scratch dir (intermediate stripped GLBs).
# The final compressed bundle under tauri/ui/assets/mascot/ STAYS TRACKED;
# only the temp dir produced during `npm run build:mascot` is ignored.
tauri/ui/.mascot-build-tmp/

# Phase 13-01 — Defensive whitelist for the mascot bundle.
# `assets/` is otherwise untouched by global ignores, but be explicit so the
# committed bundle (GLB + manifest.json + MANIFEST.md) survives future
# generic-glob ignore additions.
!tauri/ui/assets/mascot/**

# Phase 18 Plan 18-04 — Tauri updater keys NEVER live in repo.
# The procedure in tauri/src-tauri/keys/README.md instructs Kaan to store
# the .key + .key.pub files OUTSIDE the repo (~/.tauri/vibemix_updater.key{,.pub}).
# These entries are defense-in-depth: if a keypair is ever accidentally
# dropped into the directory, git refuses to track it.
tauri/src-tauri/keys/*.key
tauri/src-tauri/keys/*.key.pub

# ---------------------------------------------------------------------------
# Phase 19 — Repo hygiene (GH-18)
# ---------------------------------------------------------------------------
# Defense-in-depth even though POC's cohost.streaming.py.bak stays tracked:
# any *new* .bak file is scratch and should not enter the repo.
*.bak

# v5 session screenshots produced by the design-iteration shoots cluttering
# git status during Phase 11-14. They live under repo root and are scratch.
v5-*.png

# Claude Code worktrees + Playwright MCP scratch dirs are per-agent / per-run
# state and must never be tracked.
.claude/worktrees/
.playwright-mcp/

# Node modules at repo root (e.g. from running ``npx`` against the repo root).
# Tauri-specific node_modules under ``tauri/ui/`` already ignored above.
/node_modules/

# Docs assets (Phase 19) — Plan 19-03/04 ship hero.png + architecture.svg.
# Defensive whitelist so future generic image globs don't suppress them.
!docs/assets/
!docs/assets/**

# Phase 17 Plan 06 — tune_detectors.py default output. Per-run CSVs can be
# large; copy the relevant CSV under .planning/ if you want it versioned
# alongside the threshold change it justifies (T-17-06-04 mitigation).
tuning_runs/
