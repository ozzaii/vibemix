{
  "identifier": "default",
  "permissions": [
    "core:app:default",
    "core:default",
    "core:event:default",
    "core:path:default",
    "core:webview:default",
    "core:window:allow-start-dragging",
    "core:window:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "macos-permissions:allow-check-accessibility-permission",
    "macos-permissions:allow-check-microphone-permission",
    "macos-permissions:allow-check-screen-recording-permission",
    "macos-permissions:allow-request-accessibility-permission",
    "macos-permissions:allow-request-microphone-permission",
    "macos-permissions:allow-request-screen-recording-permission",
    "macos-permissions:default",
    "positioner:default",
    "process:default",
    "store:default",
    "updater:default",
    {
      "allow": [
        {
          "args": [
            {
              "validator": ".*audio_config\\.py$"
            },
            {
              "validator": "^--(probe-48k|configure-routing|probe-only|remove-routing)$"
            }
          ],
          "cmd": "python3",
          "name": "python3"
        },
        {
          "args": [
            {
              "validator": ".*fetch_drivers\\.sh$"
            },
            {
              "validator": "^--(dry-run|auto|check-syntax)$"
            }
          ],
          "cmd": "bash",
          "name": "bash"
        },
        {
          "args": [
            {
              "validator": "^--(wizard|session|debrief)$"
            },
            {
              "validator": "^\\d{8}-\\d{6}$"
            }
          ],
          "name": "binaries/vibemix-core",
          "sidecar": true
        },
        {
          "args": [
            {
              "validator": "^-NoProfile$"
            },
            {
              "validator": "^-ExecutionPolicy$"
            },
            {
              "validator": "^Bypass$"
            },
            {
              "validator": "^-File$"
            },
            {
              "validator": ".*fetch_drivers\\.ps1$"
            },
            {
              "validator": "^-(Auto|DryRun)$"
            }
          ],
          "cmd": "powershell.exe",
          "name": "powershell"
        },
        {
          "args": [
            {
              "validator": "^-a$"
            },
            {
              "validator": "^Audio MIDI Setup$"
            }
          ],
          "cmd": "open",
          "name": "open"
        },
        {
          "args": [
            {
              "validator": "^mmsys\\.cpl,,\\d+$"
            }
          ],
          "cmd": "control.exe",
          "name": "control"
        }
      ],
      "identifier": "shell:allow-execute"
    },
    {
      "allow": [
        {
          "path": "$APPDATA/vibemix/recordings/**/*"
        },
        {
          "path": "$APPLOCALDATA/vibemix/recordings/**/*"
        },
        {
          "url": "https://existential.audio/blackhole"
        },
        {
          "url": "https://github.com/bravoh-ai/vibemix"
        },
        {
          "url": "x-apple.systempreferences:com.apple.preference.security?Privacy_Microphone"
        },
        {
          "url": "x-apple.systempreferences:com.apple.preference.security?Privacy_ScreenCapture"
        }
      ],
      "identifier": "shell:allow-open"
    },
    {
      "allow": [
        {
          "path": "$APPLOCALDATA/vibemix/logs/sidecar.log"
        }
      ],
      "identifier": "fs:allow-read-text-file"
    }
  ],
  "windows": [
    "debrief",
    "main",
    "mascot",
    "overlay-*"
  ]
}
