// vibemix — Tauri 2.x app configuration (Phase 11 Wave 2)
//
// LOCKED VALUES (do NOT change after Phase 11):
//   - identifier: world.bravoh.vibemix  (D-Area-1 + entitlements.plist; permissions reset on change)
//   - bundle.externalBin: binaries/vibemix-core  (Wave 1 build_sidecar.py output path)
//   - app.windows[0]: 960×680, decorations:false (UI-SPEC §Window Dimensions)
//
// Phase 18 takes over signing/notarization with the hardenedRuntime + entitlements.plist.
// Tauri 2 supports JSON5 here (comments + trailing commas allowed).
{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibemix",
  "version": "0.0.1",
  "identifier": "world.bravoh.vibemix",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "vibemix",
        "width": 960,
        "height": 680,
        "minWidth": 960,
        "minHeight": 680,
        "maxWidth": 960,
        "maxHeight": 680,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "fullscreen": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "center": true,
        "visible": true
      }
      // Phase 13 Plan 02 — the mascot overlay window is built at runtime
      // by `mascot_window::create_mascot_window` in main.rs .setup()
      // (transparent + always_on_top + skip_taskbar + visible_on_all_
      // workspaces, geometry from MascotWindowState). A static entry here
      // would collide with the runtime `WebviewWindowBuilder::new(app,
      // "mascot", ...)` call ("a webview with label `mascot` already
      // exists"). capabilities/default.json's `"windows": ["main", "mascot"]`
      // is the only place that needs to know the label — it's a
      // runtime command-scope allowlist, not a creation requirement.
    ],
    "security": {
      // CSP scope:
      //   - default-src 'self' — block external origins for everything not
      //     explicitly overridden.
      //   - script-src 'self' 'wasm-unsafe-eval' — Three.js DRACOLoader
      //     instantiates WASM (KHR_draco_mesh_compression on the mascot
      //     character GLB). Without 'wasm-unsafe-eval', WebAssembly.instantiate
      //     is blocked and the character mesh fails to load.
      //   - worker-src 'self' blob: — DRACOLoader spawns its decoder Worker
      //     via `new Worker(URL.createObjectURL(new Blob(...)))`. blob: must
      //     be allowed for the worker to be constructed.
      //   - connect-src 'self' ws://127.0.0.1:8765 — Plan 13-06 added the
      //     mascot webview's own WS subscription to the sidecar bus.
      //     'self' alone blocks ws://127.0.0.1:8765 (different origin).
      //   - media-src 'self' asset: http://asset.localhost — Phase 15 Plan
      //     02. The recording browser's <audio> elements resolve voice.wav
      //     via convertFileSrc(absPath) → asset://localhost/<path>.
      //     Without media-src, the browser engine silently refuses the
      //     load and the <audio> duration stays at "--:--" (RESEARCH
      //     Pitfall 1). http://asset.localhost is the http-scheme form
      //     emitted on Windows by WebView2.
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:; connect-src 'self' ws://127.0.0.1:8765; media-src 'self' asset: http://asset.localhost",
      // Phase 15 Plan 02 — assetProtocol exposes the recordings dir to the
      // webview via asset://localhost/<absolute-path> URLs. Scope locked
      // to BOTH $APPDATA and $APPLOCALDATA variants per RESEARCH Pitfall
      // 2: on macOS both resolve to ~/Library/Application Support/vibemix
      // (so one is a no-op); on Windows $APPDATA = Roaming and
      // $APPLOCALDATA = Local — listing both is the defensive pattern so
      // a future move of the recordings dir between roaming/local doesn't
      // silently break playback. NO new permission identifier — the
      // asset protocol is plugin-less in Tauri 2.
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/vibemix/recordings/**",
          "$APPLOCALDATA/vibemix/recordings/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    // externalBin path is RELATIVE to src-tauri/. Tauri appends the target-triple suffix
    // automatically; the Wave 1 build script lays out binaries/vibemix-core-<triple>/<binary>.
    "externalBin": ["binaries/vibemix-core"],
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "12.3",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "providerShortName": null,
      // No frameworks bundled at the Tauri layer; PyInstaller ships everything inside the sidecar bundle.
      "frameworks": []
    }
  },
  "plugins": {
    "updater": {
      // Phase 18 Plan 18-04 — live updater config (replaces the Phase 11 STUB).
      //
      // `active: true` enables the plugin's plugin:updater|check command
      // (capability already granted via `updater:default` in
      // capabilities/default.json line 16).
      //
      // `endpoints` URL template — `{{target}}` becomes `darwin`/`windows`,
      // `{{arch}}` becomes `aarch64`/`x86_64`, `{{current_version}}` becomes
      // the running app's version. The server returns 204 No Content if the
      // running version is the latest; 200 with a
      // `{ version, url, signature, notes, pub_date }` JSON envelope if an
      // update is available. See docs/updater.md for the full contract.
      //
      // `pubkey` — base64-encoded minisign public key. CURRENT VALUE IS A
      // PLACEHOLDER. Kaan must replace before tagging v0.1.0 by:
      //   1. `npx @tauri-apps/cli signer generate -w ~/.tauri/vibemix_updater.key`
      //   2. `cat ~/.tauri/vibemix_updater.key.pub | base64 | tr -d '\n'`
      //   3. Paste the result here, overwriting the placeholder.
      //   4. Store the matching private-key file's base64 contents as the
      //      GitHub secret TAURI_UPDATER_PRIVATE_KEY and the passphrase as
      //      TAURI_UPDATER_KEY_PASSWORD (Plan 18-05).
      // Plan 18-05's release.yml refuses to build while the placeholder
      // string `TAURI_UPDATER_PLACEHOLDER` remains in this file.
      //
      // `dialog: true` — built-in update prompt (standard Tauri UX: notify
      // user, show changelog from `notes`, ask "Update now?", show progress
      // bar, restart). Update prompts are gated by `update_check_on_launch`
      // (default true) stored in tauri-plugin-store; opt-out flips it to
      // false. See tauri/src-tauri/src/updater.rs for the boot-time gate.
      "active": true,
      "endpoints": [
        "https://api.altidus.world/vibemix/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IFRBVVJJX1VQREFURVJfUExBQ0VIT0xERVI=",
      "dialog": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
