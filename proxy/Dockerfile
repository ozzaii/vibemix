# vibemix proxy — python:3.12-slim + uv-managed venv
# Build: docker build -t vibemix-proxy:0.1.0 .
# Run:   docker run --env-file proxy/.env -p 8788:8788 vibemix-proxy:0.1.0

FROM python:3.12-slim AS builder

# uv via the official wheel — pinned for reproducible builds
RUN pip install --no-cache-dir uv==0.5.0

WORKDIR /app
COPY pyproject.toml ./
# Lockfile is optional — generated by `uv sync` at build time if absent
COPY uv.lock* ./
COPY app/ ./app/

# No-dev install for runtime (--frozen will require uv.lock; fall back to
# `uv sync` without --frozen if lockfile not present yet)
RUN if [ -f uv.lock ]; then uv sync --frozen --no-dev; else uv sync --no-dev; fi

FROM python:3.12-slim AS runtime
WORKDIR /app
COPY --from=builder /app/.venv ./.venv
COPY --from=builder /app/app ./app
COPY pyproject.toml ./

ENV PATH="/app/.venv/bin:$PATH"
EXPOSE 8788

# Run as non-root (defence-in-depth; the proxy reads no filesystem secrets)
RUN useradd --uid 10001 --no-create-home appuser && chown -R appuser /app
USER appuser

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8788"]
