# vibemix proxy — server-side env. Copy to proxy/.env and fill in real values.
# The PROXY holds these — they NEVER ship in client binaries.

# Upstream API keys (server-side only)
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# JWT signing secret. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-with-256-bit-random

# Redis (Bravoh server already runs Redis; for local dev docker-compose spins up a fresh one)
REDIS_URL=redis://localhost:6379/0

# CORS — empty for v1 (no web client). Comma-separated origins when needed.
ALLOWED_ORIGINS=

# Rate limit knobs (per install_uuid)
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_PER_DAY=2000

# JWT TTL — long-lived per CONTEXT (no user login flow)
JWT_TTL_DAYS=90
